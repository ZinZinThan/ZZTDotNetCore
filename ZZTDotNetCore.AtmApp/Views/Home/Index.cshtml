@{
    ViewData["Title"] = "Home Page";
}

<form class="form-example" action="#" method="post">
<h3 class="display-4 text-center">Welcome to AYA Bank</h3><br />
<div class="mx-auto col-14 col-md-10 col-lg-6">
    <div class="form-group">
        <div class="mx-auto col-md-6">
            <label class="form-label">Card Number</label>
            <input class="form-control" type="text" placeholder="012*****210">
        </div>
    </div>
    <div class="form-group">
        <div class="mx-auto col-md-6">
            <label class="form-label">PIN</label>
            <input class="form-control" type="text" placeholder="######">
        </div>
    </div>
    <div class="d-grid gap-2 col-6 mx-auto">
        <button type="submit" class="btn btn-primary btn-customized mt-4">Login</button>
    </div>
</div>
</form>

