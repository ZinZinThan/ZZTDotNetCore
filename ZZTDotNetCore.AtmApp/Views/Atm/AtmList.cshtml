@model AtmDataModel

@{
    ViewData["Title"] = "Transaction Page";
}

<div class="container-fluid d-flex justify-content-center">
    <div class="row">
        <div class="d-grid gap-2 col-4">
            <a href="/atm/balance?id=@Model.Id" id="btnBalance" class="btn btn-info btn-lg">Balance</a>
        </div>
        <div class="d-grid gap-2 col-4">
            <a href="" id="btnDeposite" class="btn btn-success btn-lg">Deposite</a>
        </div>
        <div class="d-grid gap-2 col-4">
            <a href="" id="btnWithdraw" class="btn btn-warning btn-lg">Withdraw</a>
        </div>
        <div class="d-grid gap-2 col-4">
            <a href="" id="btnChangePin" class="btn btn-danger btn-lg">Change Pin</a>
        </div>
    </div>
</div>

