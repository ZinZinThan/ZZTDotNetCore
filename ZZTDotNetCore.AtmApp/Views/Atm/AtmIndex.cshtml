
@{
    ViewData["Title"] = "Login Page";
    string message = null;
    bool isSuccess = false;
    if(TempData["Message"] != null)
    {
        message = TempData["Message"].ToString();
        isSuccess = Convert.ToBoolean(TempData["IsSuccess"]);
    }
    if (message is not null)
    {
        <div class="mx-auto col-14 col-md-10 col-lg-6">
            <div class="form-group">
                <div class="alert alert-@(isSuccess?"success" :"danger") role="alert">
                @message
                </div>
            </div>
        </div>
    }
}

<form class="form-example" action="/atm/login" method="post">
   @*  <h4 class="display-4 text-center">Welcome to AYA Bank</h4><br /> *@
    <div class="mx-auto col-14 col-md-10 col-lg-6">
        <div class="form-group">
            <div class="mx-auto col-md-6">
                <label class="txtCard">Card Number</label>
                <input class="form-control" type="text" name="CardNumber" id="txtCard" placeholder="012*****210">
            </div>
        </div>
        <div class="form-group">
            <div class="mx-auto col-md-6">
                <label class="txtPin">PIN</label>
                <input class="form-control" type="text" name="Pin" id="txtPin" placeholder="######">
            </div>
        </div>
        <div class="d-grid gap-2 col-6 mx-auto">
            <button type="submit" id="btnLogin" class="btn btn-primary btn-customized mt-4">Login</button>
        </div>
        <div class="mx-auto col-md-6 text-center" style="margin-top:0.5rem;">
            <label class="form-label">Have no account yet?<a href="/atm/create">&nbsp;Register</a></label>
        </div>
    </div>
</form>